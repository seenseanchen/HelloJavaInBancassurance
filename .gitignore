.idea/
*.iml
*.iws
*.ipr
out/

# ----- VS Code -----
.vscode/

# ----- Maven -----
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml

# ----- Java 編譯產物 -----
*.class
*.jar
*.war
*.ear
hs_err_pid*

# ----- Spring Boot -----
*.log
spring-boot-devtools.properties
application-*.yml.local

# ----- macOS -----
.DS_Store
.AppleDouble
.LSOverride

# ----- 環境變數 / 密碼 (重要) -----
.env
.env.*
!.env.example
*.pem
*.key

# ----- Docker volume mount (萬一不小心放在專案內) -----
pgdata/
