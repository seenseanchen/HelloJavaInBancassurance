<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty name="APP_NAME" source="spring.application.name" defaultValue="bancassurance"/>
    <contextName>${APP_NAME}</contextName>

    <property name="DEV_CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [traceId=%X{traceId:-no-trace} spanId=%X{spanId:-no-span}] %logger{36} - %msg%n%ex"/>

    <!-- Default/dev: human-readable logs for local debugging -->
    <springProfile name="!docker &amp; !prod">
        <appender name="CONSOLE_HUMAN" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <pattern>${DEV_CONSOLE_PATTERN}</pattern>
            </encoder>
        </appender>

        <logger name="com.sean.bancassurance" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <logger name="org.hibernate.orm.jdbc.bind" level="TRACE"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE_HUMAN"/>
        </root>
    </springProfile>

    <!-- Docker/prod: JSON lines as structured logging baseline -->
    <springProfile name="docker | prod">
        <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="ch.qos.logback.classic.encoder.JsonEncoder">
                <withFormattedMessage>true</withFormattedMessage>
                <withArguments>false</withArguments>
                <withSequenceNumber>false</withSequenceNumber>
                <withNanoseconds>false</withNanoseconds>
                <withMDC>true</withMDC>
                <withKVPList>true</withKVPList>
            </encoder>
        </appender>

        <logger name="com.sean.bancassurance" level="INFO"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
    </springProfile>
</configuration>
